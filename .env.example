# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API Keys (Backend Only - DO NOT expose in frontend)
# These are set in Supabase Edge Functions secrets
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...
ELEVENLABS_API_KEY=...
META_ACCESS_TOKEN=...
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...

# App Configuration
VITE_APP_NAME=Apply AI
VITE_APP_URL=https://applyai.jobs
VITE_SUPPORT_EMAIL=support@applyai.jobs

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_VOICE_APPLY=true
VITE_ENABLE_ANALYTICS=true

# Monitoring (Production)
VITE_SENTRY_DSN=
VITE_GA_MEASUREMENT_ID=
